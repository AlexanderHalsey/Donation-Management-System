model DonorSyncEvent {
  id           String               @id @default(uuid()) @db.Uuid
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  requestId    String
  attempt      Int
  eventType    DonorEventType
  externalId   Int
  payload      Json
  status       DonorSyncEventStatus @default(PENDING)
  processedAt  DateTime?
  errorMessage String?
  retryCount   Int                  @default(0)

  @@unique([requestId, eventType, externalId])
}

enum DonorSyncEventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DonorEventType {
  UPSERT
  DELETE
  MERGE
}
