    "@prisma/client": "^7.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^7.0.9",
    "accept-language-parser": "^1.5.0",
    "basic-auth": "^2.0.1",
    "bcrypt": "^6.0.0",
