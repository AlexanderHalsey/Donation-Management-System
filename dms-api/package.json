    "image-size": "^2.0.2",
    "jspdf": "^3.0.4",
    "nestjs-pino": "^4.5.0",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
